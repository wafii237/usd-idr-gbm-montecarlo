Package: USDIDRProjection
Title: Proyeksi Nilai Tukar USD/IDR dengan Geometric Brownian Motion dan Simulasi Monte Carlo
Version: 1.0.0
Authors@R:
    person(
      given  = "Muhammad Faeruz Wafi",
